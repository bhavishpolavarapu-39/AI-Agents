# APEX Platform Environment Configuration

# ==============================================
# Frontend Configuration
# ==============================================
NEXT_PUBLIC_API_URL=http://localhost:8000

# ==============================================
# Backend Configuration
# ==============================================
# FastAPI Server
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/apex

# Redis Cache
REDIS_URL=redis://localhost:6379

# Qdrant Vector Database
QDRANT_URL=http://localhost:6333

# ==============================================
# Financial APIs - Market Data
# ==============================================
# Finnhub API (https://finnhub.io)
# Free tier: 60 API calls/minute, real-time quotes, news, company profiles
# Signup: https://www.finnhub.io/
FINNHUB_API_KEY=your_finnhub_api_key_here

# Alpha Vantage API (https://www.alphavantage.co)
# Free tier: 5 API calls/minute, technical indicators, time series data
# Signup: https://www.alphavantage.co/
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# ==============================================
# AI Configuration
# ==============================================
# Anthropic Claude API (https://www.anthropic.com/api)
# Used for AI agents, analysis, and multi-agent workflows
# Signup: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Claude Model Version
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# ==============================================
# CORS and Security
# ==============================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,https://ai-agents-kvjx.vercel.app

# JWT Secret for API authentication
JWT_SECRET=your_jwt_secret_key_here

# ==============================================
# Project Settings
# ==============================================
PROJECT_NAME=APEX Portfolio Intelligence Platform
VERSION=2.0.0
ENVIRONMENT=development
DEBUG=true

# ==============================================
# Optional: Vercel Deployment
# ==============================================
# For Vercel deployment, set these in your Vercel dashboard
# VERCEL_URL will be automatically set by Vercel
